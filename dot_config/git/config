[core]
    excludesfile = ~/.config/git/ignore
    autocrlf = input

    pager = delta

[init]
    defaultbranch = main

[color]
    diff = auto
    status = auto
    branch = auto
    interactive = auto
    ui = true
    pager = true

[fetch]
    prune = true

[push]
    default = current

[pull]
    prune = true
    rebase = true

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    line-numbers = true

[merge]
    conflictstyle = zdiff3

[mergetool]
    prompt = false

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

[user]
    name = Ivan Giacomelli
    email = ivan@nopsled.it
    signingkey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIFgidANFo/VdM+CDNgwp+xympHpbTj+iyQuzYPeu02x4

[includeIf "hasconfig:remote.*.url:git@github.com:fusebank/*"]
    path = config-fusebank

[gpg]
    format = ssh

[gpg "ssh"]
    program = "/Applications/1Password.app/Contents/MacOS/op-ssh-sign"
    allowedSignersFile = /Users/ivan/.ssh/allowed_signers

[commit]
    gpgsign = true

[alias]
    alias = ! git config --get-regexp ^alias\\. | sed -e s/^alias\\.// -e s/\\ /\\ =\\ /|sort

    br = branch -vv --format='%(HEAD) %(if)%(upstream)%(then)%(color:bold green)%(else)%(if)%(push)%(then)%(color:bold yellow)%(else)%(color:red)%(end)%(end)%(refname:short)%(color:reset) - %(contents:subject) %(color:magenta)(%(committerdate:relative)) [%(authorname)]' --sort=-committerdate
    df = !git diff --word-diff=color

    #count = rev-list --count HEAD
    #countall = rev-list --count --all
    #firstcommit = rev-list --max-parents=0 HEAD

    cleanup-branches = "!f() { echo \"Fetching and pruning...\"; git fetch --all --prune; branches=$(git branch -vv | grep \": gone]\" | awk \"{print \\$1}\"); if [ -n \"$branches\" ]; then echo \"Branches to delete:\"; echo \"$branches\"; read -p \"Delete these branches? (y/N) \" -n 1 -r; echo; if [[ $REPLY =~ ^[Yy]$ ]]; then echo \"$branches\" | xargs git branch -D; else echo \"Cancelled.\"; fi; else echo \"No branches to delete.\"; fi; }; f"

    wtl = worktree list
    wta = worktree add
    wtr = worktree remove
    wtp = worktree prune

    done = !git push -u origin HEAD
    undos = reset --soft HEAD~1
    undom = reset --mixed HEAD~1

    co = checkout
    com = checkout main
    cob = checkout -b

    up = pull --rebase --autostash
    lg = log --pretty=oneline -n 20 --graph --abbrev-commit
